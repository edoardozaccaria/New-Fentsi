# ============================================================
# FENTSI — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Anthropic (Claude AI) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily (Web Search for AI anti-hallucination) ─────────────
# Required to prevent AI from inventing vendor data
# Get a free key at: https://tavily.com → Dashboard → API Keys
TAVILY_API_KEY=tvly-...

# ── Foursquare Places API ─────────────────────────────────────
# Free tier: 1,000 calls/day — no credit card required
# Create an app at: https://location.foursquare.com/developer/
FOURSQUARE_API_KEY=fsq3...

# ── Stripe ────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs (create these in Stripe Dashboard → Products)
STRIPE_SINGLE_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...
STRIPE_COORDINATION_PRICE_ID=price_...

# ── Upstash Redis (rate limiting — required in production) ────
# Create a Redis DB at: https://console.upstash.com
# Falls back to in-memory if not set (local dev only)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Environment tag — used for analytics & error tracking
# Values: development | staging | production
NEXT_PUBLIC_ENV=development

# ============================================================
# SETUP ORDER
# 1. Supabase  → supabase.com → new project
#    → Run supabase/migrations/001_initial_schema.sql
#    → Run supabase/migrations/002_auth_security.sql
#    → Enable Email Auth in Authentication → Settings
# 2. Anthropic → console.anthropic.com → API Keys
# 3. Foursquare → location.foursquare.com/developer → new app
# 4. Stripe → dashboard.stripe.com → Products → create price IDs
# 5. npm install && npm run dev
# ============================================================
