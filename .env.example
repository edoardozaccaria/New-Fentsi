# ============================================================
# .env.example — Template condiviso con il team via git.
# NON contiene valori reali. Copia questo file e rinominalo
# in .env.development, .env.staging o .env.production.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/fentsi_dev

# --- Authentication (e.g. NextAuth / Clerk) ---
AUTH_SECRET=your-secret-here
NEXT_PUBLIC_AUTH_PROVIDER_URL=

# --- External APIs ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SINGLE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
STRIPE_COORDINATION_PRICE_ID=

# --- Monitoring ---
SENTRY_DSN=

# --- Supabase ---
# Provider setup (done in Supabase dashboard, not env):
#   1. Auth → Providers → Google → paste Client ID + Secret from Google Cloud
#   2. Auth → URL Configuration → Site URL = http://localhost:3000 (dev) / production URL
#   3. Auth → URL Configuration → Redirect URLs → add http://localhost:3000/auth/callback
#   4. (Optional) Auth → Providers → Apple → Service ID + private key (requires Apple Developer account)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth feature flags ---
# Set to "true" only after enabling the Apple provider in the Supabase dashboard
# and configuring Service ID + key from a paid Apple Developer account.
NEXT_PUBLIC_APPLE_AUTH_ENABLED=false

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-

# --- Tavily ---
TAVILY_API_KEY=

# --- Foursquare ---
FOURSQUARE_API_KEY=

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000

# Deals aggregators — affiliate programs
# Sign up at: https://www.booking.com/affiliate-program/
BOOKING_AFFILIATE_ID=

# Sign up at: https://affiliate-program.amazon.com/
AMAZON_ASSOCIATES_TAG=
