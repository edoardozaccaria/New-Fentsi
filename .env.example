# ============================================================
# .env.example — Template condiviso con il team via git.
# NON contiene valori reali. Copia questo file e rinominalo
# in .env.development, .env.staging o .env.production.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/fentsi_dev

# --- Authentication (e.g. NextAuth / Clerk) ---
AUTH_SECRET=your-secret-here
NEXT_PUBLIC_AUTH_PROVIDER_URL=

# --- External APIs ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SINGLE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
STRIPE_COORDINATION_PRICE_ID=

# --- Monitoring ---
SENTRY_DSN=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-

# --- Tavily ---
TAVILY_API_KEY=

# --- Foursquare ---
FOURSQUARE_API_KEY=

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
