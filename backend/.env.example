# ──────────────────────────────────────────────
# Fentsi Backend — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# ─── Database ─────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/fentsi?schema=public"

# ─── Redis ────────────────────────────────────
# Used for BullMQ job queues and caching
REDIS_URL="redis://localhost:6379"

# ─── Authentication ───────────────────────────
# Secret for signing access tokens (min 32 chars, random)
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# Secret for signing refresh tokens (different from JWT_SECRET)
JWT_REFRESH_SECRET="change-me-to-another-random-secret-at-least-32-chars"

# ─── AI ───────────────────────────────────────
# Anthropic API key for Claude plan generation
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Vendor Search ────────────────────────────
# Foursquare Places API key for venue/vendor discovery
FOURSQUARE_API_KEY="fsq3..."

# ─── Email ────────────────────────────────────
# Resend API key for transactional emails
RESEND_API_KEY="re_..."

# ─── File Storage (Cloudflare R2) ─────────────
# R2-compatible S3 endpoint
CLOUDFLARE_R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# R2 bucket name
CLOUDFLARE_R2_BUCKET="fentsi-uploads"

# R2 access credentials (Workers API tokens)
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""

# Public URL prefix for serving R2 objects
CLOUDFLARE_R2_PUBLIC_URL="https://assets.fentsi.com"

# ─── Application ──────────────────────────────
# Frontend URL for CORS and email links
FRONTEND_URL="http://localhost:3000"

# Port the backend listens on
PORT=4000

# Environment: development | staging | production
NODE_ENV="development"
